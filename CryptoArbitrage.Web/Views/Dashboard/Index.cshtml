@{
    ViewData["Title"] = "Dashboard - CryptoManager";
}

<section class="hero-header mb-4" id="overview">
    <div class="hero-copy">
        <p class="hero-kicker">Crypto Arbitrage Command Center</p>
        <h1>Trading Operations</h1>
        <p class="hero-text">Welcome back, @ViewData["Username"]! Monitor balances, live spreads, and execution status at a glance.</p>
        <div class="hero-actions">
            <a class="primary-btn action-btn" asp-controller="Wallet" asp-action="Index">Go to Wallet</a>
            <a class="primary-btn action-btn" asp-controller="Prices" asp-action="Index">Open Trading Desk</a>
            <a class="primary-btn action-btn" asp-controller="Analytics" asp-action="Index">View Analytics</a>
        </div>
    </div>
    <div class="hero-stats">
        <div class="hero-stat">
            <span class="hero-stat-label">Live source</span>
            <strong>Binance + Kraken</strong>
        </div>
        <div class="hero-stat">
            <span class="hero-stat-label">Active strategy</span>
            <strong>Simple Arbitrage</strong>
        </div>
        <div class="hero-stat">
            <span class="hero-stat-label">Persistence</span>
            <strong>SQL Server snapshots</strong>
        </div>
    </div>
</section>

<section class="dashboard-kpis mb-4">
    <article class="glass-card kpi-card">
        <p class="kpi-label">Portfolio Balance</p>
        <p class="kpi-value">$12,394.52</p>
        <p class="kpi-meta">Primary wallet | USDT</p>
    </article>
    <article class="glass-card kpi-card">
        <p class="kpi-label">Today Profit</p>
        <p class="kpi-value">$412.80</p>
        <p class="kpi-meta">8 successful trades</p>
    </article>
    <article class="glass-card kpi-card">
        <p class="kpi-label">Live Spread</p>
        <p class="kpi-value">1.07%</p>
        <p class="kpi-meta">BTC | Kraken -> Binance</p>
    </article>
    <article class="glass-card kpi-card">
        <p class="kpi-label">Snapshots Stored</p>
        <p class="kpi-value">9</p>
        <p class="kpi-meta">Last: trade-sell</p>
    </article>
    <article class="glass-card kpi-card kpi-chart-card">
        <p class="kpi-label">Mini Charts</p>
        <div class="mini-chart">
            <div class="mini-chart-header">
                <span>Profit today</span>
                <strong>$412.80</strong>
            </div>
            <div class="mini-bars" aria-hidden="true">
                <span style="--bar: 38%"></span>
                <span style="--bar: 55%"></span>
                <span style="--bar: 22%"></span>
                <span style="--bar: 72%"></span>
                <span style="--bar: 46%"></span>
                <span style="--bar: 64%"></span>
                <span style="--bar: 88%"></span>
            </div>
        </div>
        <div class="mini-chart">
            <div class="mini-chart-header">
                <span>Opportunities</span>
                <strong>14 today</strong>
            </div>
            <div class="mini-bars" aria-hidden="true">
                <span style="--bar: 24%"></span>
                <span style="--bar: 44%"></span>
                <span style="--bar: 31%"></span>
                <span style="--bar: 58%"></span>
                <span style="--bar: 36%"></span>
                <span style="--bar: 68%"></span>
                <span style="--bar: 52%"></span>
            </div>
        </div>
    </article>
</section>

</section>
