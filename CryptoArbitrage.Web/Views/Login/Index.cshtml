@{
    ViewData["Title"] = "Login - CryptoManager";
}

<div class="login-container">
    <div class="login-card glass-card">
        <div class="login-header">
            <h1>CryptoManager</h1>
            <p class="login-subtitle">Patterns in motion</p>
            <p class="login-description">Crypto Portfolio Command Center</p>
        </div>

        <form method="post" action="/Login/Login" class="login-form">
            @Html.AntiForgeryToken()
            
            <div class="form-group">
                <label for="username">Username</label>
                <div class="input-wrapper">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    <input 
                        type="text" 
                        id="username" 
                        name="username" 
                        class="form-control login-input"
                        placeholder="Enter your username" 
                        required 
                        minlength="3" />
                </div>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <div class="input-wrapper">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        class="form-control login-input"
                        placeholder="Enter your password" 
                        required 
                        minlength="3" />
                </div>
            </div>

            <div class="form-group remember-group">
                <label class="remember-label">
                    <input 
                        type="checkbox" 
                        id="rememberMe" 
                        name="rememberMe" 
                        class="remember-checkbox" />
                    <span>Remember me</span>
                </label>
            </div>

            @if (ViewData["Error"] != null)
            {
                <div class="alert alert-danger login-error">
                    @ViewData["Error"]
                </div>
            }

            <button type="submit" class="login-btn primary-btn">Login</button>
        </form>

        <div class="login-footer">
            <p>Users are saved on first login. Use any username/password (min 3 chars).</p>
        </div>
    </div>
</div>

<style>
.login-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background: linear-gradient(135deg, rgba(0, 150, 150, 0.1) 0%, rgba(0, 100, 150, 0.15) 100%);
}

.login-card {
    width: 100%;
    max-width: 400px;
    padding: 40px;
    border: 1px solid rgba(0, 220, 180, 0.3);
    border-radius: 12px;
    background: rgba(15, 25, 40, 0.8);
    backdrop-filter: blur(10px);
}

.login-header {
    text-align: center;
    margin-bottom: 30px;
}

.login-header h1 {
    font-size: 28px;
    color: #00dcb4;
    margin: 0 0 5px 0;
    font-weight: 700;
}

.login-subtitle {
    font-size: 12px;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 5px 0;
}

.login-description {
    font-size: 14px;
    color: #aaa;
    margin-top: 10px;
}

.login-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.form-group label {
    color: #aaa;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.login-input {
    padding: 12px 14px;
    background: rgba(0, 220, 180, 0.05);
    border: 1px solid rgba(0, 220, 180, 0.2);
    border-radius: 6px;
    color: #fff;
    font-size: 14px;
    transition: all 0.3s ease;
}

.login-input:focus {
    outline: none;
    background: rgba(0, 220, 180, 0.1);
    border-color: rgba(0, 220, 180, 0.5);
    box-shadow: 0 0 10px rgba(0, 220, 180, 0.2);
}

.login-btn {
    padding: 12px 20px;
    background: linear-gradient(135deg, #00dcb4 0%, #00b8a0 100%);
    color: #0a1929;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.login-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0, 220, 180, 0.3);
}

.login-error {
    background: rgba(220, 50, 50, 0.1);
    border: 1px solid rgba(220, 50, 50, 0.3);
    color: #ff6b6b;
    padding: 12px;
    border-radius: 6px;
    font-size: 13px;
    margin-top: 10px;
}

.login-footer {
    text-align: center;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid rgba(0, 220, 180, 0.1);
}

.login-footer p {
    color: #888;
    font-size: 12px;
    margin: 0;
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.input-icon {
    position: absolute;
    left: 12px;
    width: 18px;
    height: 18px;
    color: rgba(0, 220, 180, 0.5);
    pointer-events: none;
    flex-shrink: 0;
}

.input-wrapper .login-input {
    padding-left: 40px;
}

.remember-group {
    margin: 15px 0;
}

.remember-label {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    color: #aaa;
    font-size: 13px;
    user-select: none;
    transition: color 0.3s ease;
}

.remember-label:hover {
    color: #00dcb4;
}

.remember-checkbox {
    width: 16px;
    height: 16px;
    cursor: pointer;
    accent-color: #00dcb4;
}
</style>
