<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CryptoArbitrage.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CryptoArbitrage.Web.styles.css" asp-append-version="true" />
</head>
<body class="crypto-dashboard">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark crypto-nav border-0 shadow-sm mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold d-flex flex-column lh-sm" asp-area="" asp-controller="Home" asp-action="Index">
                    <span>CryptoManager</span>
                    <small class="brand-subtitle">Patterns in motion</small>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-sm-2">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" href="#how-it-works">How it works</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" href="#architecture-map">Architecture map</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" href="#live-dashboard">Live dashboard</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer crypto-footer text-muted">
        <div class="container site-footer-inner">
            <div>
                <strong>CryptoManager</strong>
                <div class="footer-note">Live arbitrage dashboard with Strategy, Observer, Command, Memento, Iterator and SQL Server persistence.</div>
            </div>
            <div class="footer-links">
                <a href="#overview">Overview</a>
                <a href="#architecture-map">Architecture map</a>
                <a href="#live-dashboard">Dashboard</a>
            </div>
            <div>&copy; 2026 - CryptoArbitrage.Web</div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
