@{
    ViewData["Title"] = "Prices & Trading - CryptoManager";
}

<section class="hero-header mb-4">
    <div class="hero-copy">
        <p class="hero-kicker">Real-time Trading</p>
        <h1>Prices & Trading</h1>
        <p class="hero-text">Monitor prices and execute trades.</p>
    </div>
</section>

<section class="dashboard-grid">
    <article class="glass-card" id="pricesCard" style="grid-column: 1 / -1;">
        <header class="card-head">
            <span class="card-icon">PX</span>
            <h2>Crypto Prices</h2>
            <span class="pill">Flyweight cards</span>
        </header>
        <div class="form-row" style="margin-bottom:12px;">
            <div>
                <label for="strategyType">Arbitrage Strategy</label>
                <select id="strategyType" name="strategyType">
                    <option value="simple">Simple</option>
                    <option value="spread">Spread Based</option>
                    <option value="triangular">Triangular</option>
                </select>
            </div>
            <div>
                <label for="liveSymbol">Live Symbol</label>
                <select id="liveSymbol" name="liveSymbol"></select>
            </div>
        </div>
        <div class="prices-wrap" id="pricesList"></div>
        <canvas id="pricesChart" height="120" aria-label="Prices chart"></canvas>
        <section class="tx-decorator" id="observerFeed" style="margin-top:12px;">
            <p><strong>Observer feed</strong></p>
            <ul id="observerEvents" style="margin:8px 0 0 18px;"></ul>
        </section>
    </article>

    <article class="glass-card" id="commandCard">
        <header class="card-head">
            <span class="card-icon">CE</span>
            <h2>Trade Command Engine</h2>
            <span class="pill">Behavioral Command</span>
        </header>
        <form id="tradeCommandForm" class="tx-form" novalidate>
            <div class="form-row">
                <div>
                    <label for="tradeExchange">Exchange</label>
                    <select id="tradeExchange" name="exchange">
                        <option value="binance">Binance</option>
                        <option value="kraken">Kraken</option>
                    </select>
                </div>
                <div>
                    <label for="tradeSide">Side</label>
                    <select id="tradeSide" name="side">
                        <option value="buy">Buy</option>
                        <option value="sell">Sell</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div>
                    <label for="tradePair">Pair</label>
                    <input id="tradePair" name="pair" type="text" value="BTC/USDT" required />
                </div>
                <div>
                    <label for="tradeAmount">Amount</label>
                    <input id="tradeAmount" name="amount" type="number" step="0.0001" min="0.0001" value="0.1" required />
                </div>
            </div>

            <label for="tradePrice">Price</label>
            <input id="tradePrice" name="price" type="number" step="0.01" min="0.01" value="65000" required />

            <div class="form-row" style="margin-top:10px;">
                <button class="primary-btn" type="submit">Execute Command</button>
                <button class="primary-btn" id="undoTradeCommandBtn" type="button">Undo Last Command</button>
            </div>

            <div class="form-row" style="margin-top:10px;">
                <div>
                    <label for="snapshotLabel">Snapshot label</label>
                    <input id="snapshotLabel" name="snapshotLabel" type="text" value="manual-snapshot" />
                </div>
                <div>
                    <label for="snapshotSelect">Saved snapshots</label>
                    <select id="snapshotSelect" name="snapshotSelect"></select>
                </div>
            </div>

            <div class="form-row" style="margin-top:10px;">
                <button class="primary-btn" id="saveBotStateBtn" type="button">Save Bot State</button>
                <button class="primary-btn" id="restoreBotStateBtn" type="button">Restore Selected State</button>
            </div>

            <p class="meta-line persistence-status" id="persistenceStatus">SQL Server persistence is loading...</p>

            <p class="inline-error" id="tradeCommandError" hidden></p>
            <section class="tx-decorator" style="margin-top:10px;">
                <p><strong>Command result:</strong> <span id="tradeCommandResult">-</span></p>
                <p><strong>History count:</strong> <span id="tradeCommandHistory">0</span></p>
                <p><strong>Active strategy:</strong> <span id="botActiveStrategy">-</span></p>
            </section>
        </form>
    </article>
</section>

<div class="toast-stack" id="toastStack" aria-live="polite" aria-atomic="true"></div>

@section Scripts {
    <script type="module" src="~/js/dashboard/dashboard.js" asp-append-version="true"></script>
}
