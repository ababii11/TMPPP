@{
    ViewData["Title"] = "Prices & Trading - CryptoManager";
}

<section class="hero-header mb-4">
    <div class="hero-copy">
        <p class="hero-kicker">Real-time Trading</p>
        <h1>Prices & Trading</h1>
        <p class="hero-text">Pick a strategy, inspect live spreads, then execute and review trades from the command panel.</p>
    </div>
</section>

<section class="glass-card trading-flow-card mb-4">
    <header class="card-head">
        <span class="card-icon">FL</span>
        <h2>Trading Flow</h2>
        <span class="pill">Where things happen</span>
    </header>
    <div class="trading-flow-grid">
        <div class="flow-step">
            <span class="flow-step-no">1</span>
            <div>
                <h3>Market view</h3>
                <p>Live prices, spread chart, and strategy evaluation are shown in the left panel.</p>
            </div>
        </div>
        <div class="flow-step">
            <span class="flow-step-no">2</span>
            <div>
                <h3>Trade execution</h3>
                <p>Use the command engine on the right to submit buy/sell orders and undo the last command.</p>
            </div>
        </div>
        <div class="flow-step">
            <span class="flow-step-no">3</span>
            <div>
                <h3>Results & audit</h3>
                <p>Command results, history, observer events, and snapshots show what happened after execution.</p>
            </div>
        </div>
    </div>
</section>

<section class="dashboard-grid trading-grid">
    <article class="glass-card trading-market-card" id="pricesCard">
        <header class="card-head">
            <span class="card-icon">PX</span>
            <h2>Crypto Prices</h2>
            <span class="pill">Flyweight cards</span>
        </header>
        <div class="prices-controls">
            <div class="prices-control-block">
                <span class="prices-control-label">Arbitrage strategy</span>
                <div class="strategy-segments" id="strategySegments" role="group" aria-label="Arbitrage strategy">
                    <button type="button" class="strategy-seg is-active" data-strategy="simple" aria-pressed="true">Simple</button>
                    <button type="button" class="strategy-seg" data-strategy="spread" aria-pressed="false">Spread</button>
                    <button type="button" class="strategy-seg" data-strategy="triangular" aria-pressed="false">Triangular</button>
                </div>
                <select id="strategyType" name="strategyType" class="strategy-select-sync" title="Strategy value for API">
                    <option value="simple">Simple</option>
                    <option value="spread">Spread Based</option>
                    <option value="triangular">Triangular</option>
                </select>
            </div>
            <div class="prices-control-block">
                <label class="prices-control-label" for="liveSymbol">Live symbol</label>
                <select id="liveSymbol" name="liveSymbol" class="live-symbol-select">
                    <option value="BTC">BTC</option>
                    <option value="ETH">ETH</option>
                    <option value="SOL">SOL</option>
                    <option value="ADA">ADA</option>
                </select>
                <p class="live-symbol-hint">Choose the pair you want to watch; the strategy buttons refresh the live view immediately.</p>
            </div>
        </div>

        <div id="strategyVizBoard" class="strategy-viz-board" aria-live="polite">
            <p class="strategy-route-line">Select a strategy and symbol to load the live spread evaluation.</p>
        </div>

        <div class="prices-wrap" id="pricesList"></div>

        <div class="chart-panel">
            <div class="chart-panel-head">
                <span class="chart-panel-title">Live spread by exchange</span>
                <span class="live-pulse" id="chartLiveStatus"><span class="live-pulse-dot" aria-hidden="true"></span> Live</span>
                <span id="chartLastSync" class="chart-sync-age" aria-live="polite"></span>
            </div>
            <div id="chartLegend" class="chart-legend" aria-hidden="true"></div>
            <canvas id="pricesChart" height="220" aria-label="Live price spread chart"></canvas>
        </div>
        <section class="tx-decorator" id="observerFeed" style="margin-top:12px;">
            <p><strong>Observer feed</strong></p>
            <ul id="observerEvents" style="margin:8px 0 0 18px;"></ul>
        </section>
    </article>

    <article class="glass-card trading-command-card" id="commandCard">
        <header class="card-head">
            <span class="card-icon">CE</span>
            <h2>Trade Command Engine</h2>
            <span class="pill">Behavioral Command</span>
        </header>
        <form id="tradeCommandForm" class="tx-form" novalidate>
            <div class="form-row">
                <div>
                    <label for="tradeExchange">Exchange</label>
                    <select id="tradeExchange" name="exchange">
                        <option value="binance">Binance</option>
                        <option value="kraken">Kraken</option>
                    </select>
                </div>
                <div>
                    <label for="tradeSide">Side</label>
                    <select id="tradeSide" name="side">
                        <option value="buy">Buy</option>
                        <option value="sell">Sell</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div>
                    <label for="tradePair">Pair</label>
                    <input id="tradePair" name="pair" type="text" value="BTC/USDT" required />
                </div>
                <div>
                    <label for="tradeAmount">Amount</label>
                    <input id="tradeAmount" name="amount" type="number" step="0.0001" min="0.0001" value="0.1" required />
                </div>
            </div>

            <label for="tradePrice">Price</label>
            <input id="tradePrice" name="price" type="number" step="0.01" min="0.01" value="65000" required />

            <div class="form-row" style="margin-top:10px;">
                <button class="primary-btn" type="submit">Execute Command</button>
                <button class="primary-btn" id="undoTradeCommandBtn" type="button">Undo Last Command</button>
            </div>

            <div class="form-row" style="margin-top:10px;">
                <div>
                    <label for="snapshotLabel">Snapshot label</label>
                    <input id="snapshotLabel" name="snapshotLabel" type="text" value="manual-snapshot" />
                </div>
                <div>
                    <label for="snapshotSelect">Saved snapshots</label>
                    <select id="snapshotSelect" name="snapshotSelect"></select>
                </div>
            </div>

            <div class="form-row" style="margin-top:10px;">
                <button class="primary-btn" id="saveBotStateBtn" type="button">Save Bot State</button>
                <button class="primary-btn" id="restoreBotStateBtn" type="button">Restore Selected State</button>
            </div>

            <p class="meta-line persistence-status" id="persistenceStatus">SQL Server persistence is loading...</p>

            <p class="inline-error" id="tradeCommandError" hidden></p>
            <section class="tx-decorator" style="margin-top:10px;">
                <p><strong>Command result:</strong> <span id="tradeCommandResult">-</span></p>
                <p><strong>History count:</strong> <span id="tradeCommandHistory">0</span></p>
                <p><strong>Active strategy:</strong> <span id="botActiveStrategy">-</span></p>
            </section>
        </form>
    </article>
</section>

<div class="toast-stack" id="toastStack" aria-live="polite" aria-atomic="true"></div>

@section Scripts {
    <script type="module" src="~/js/dashboard/dashboard.js" asp-append-version="true"></script>
}
